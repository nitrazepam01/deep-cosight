# ===== 通用配置 =====
ENVIRONMENT=development

# ===== 急速模式配置 =====
TURBO_MODE=False

# ===== 上下文管理配置 =====
ENABLE_CONTEXT_COMPRESSION=false
MAX_CONTEXT_TOKENS=128000
COMPRESSION_THRESHOLD=0.8
KEEP_INITIAL_TURNS=2
KEEP_RECENT_TURNS=3

# 消息截断配置
MAX_MESSAGES=30
MAX_TOOL_CONTENT_LENGTH=50000

# ===== LLM连接超时配置 =====
LLM_TIMEOUT=180

# ===== 代理配置 =====
# PROXY_URL=
# HTTPS_PROXY=${PROXY_URL}
# HTTP_PROXY=${PROXY_URL}

# ===== MODEL（必填） =====
API_KEY=your-api-key-here
API_BASE_URL=https://your-api-base-url/v1
MODEL_NAME=your-model-name
MAX_TOKENS=4096
TEMPERATURE=0.0
PROXY=

# ===== 工具API =====
# GOOGLE
GOOGLE_API_KEY=
SEARCH_ENGINE_ID=

# TAVILY
TAVILY_API_KEY=your-tavily-api-key

# ====== Browser Use Config ======
HEADLESS=False
DISABLE_SECURITY=False
FORCE_KEEP_BROWSER_ALIVE=False
MINIMUM_WAIT_PAGE_LOAD_TIME=5.0
WAIT_FOR_NETWORK_IDLE_PAGE_LOAD_TIME=5.0
WAIT_BETWEEN_ACTIONS=3.0
BROWSER_PROXY_URL=
BROWSER_PROXY_USER=
BROWSER_PROXY_PASSWORD=
ADD_SCHEMA_TO_SYSTEM_PROMPT=
FLASH_MODE=True
MAX_TOKENS_PER_STEP=1

# ===== MODEL 进阶配置（可选） =====
# 可分层配置：规划、执行、工具、多模态、可信信息分析、浏览器自动化
# API_KEY、API_BASE_URL、MODEL_NAME 都配置方可生效

# # ===== PLAN MODEL =====
# PLAN_API_KEY=
# PLAN_API_BASE_URL=
# PLAN_MODEL_NAME=

# # ===== ACT MODEL =====
# ACT_API_KEY=
# ACT_API_BASE_URL=
# ACT_MODEL_NAME=

# # ===== TOOL MODEL =====
# TOOL_API_KEY=
# TOOL_API_BASE_URL=
# TOOL_MODEL_NAME=

# # ===== VISION MODEL =====
# VISION_API_KEY=
# VISION_API_BASE_URL=
# VISION_MODEL_NAME=

# # ===== 可信信息分析 MODEL =====
# CREDIBILITY_API_KEY=
# CREDIBILITY_API_BASE_URL=
# CREDIBILITY_MODEL_NAME=

# # ===== Browser Model =====
# BROWSER_API_KEY=
# BROWSER_API_BASE_URL=
# BROWSER_MODEL_NAME=

# ========== LightRAG 知识库配置 ==========
LIGHTRAG_BASE_URL=http://localhost:9621
LIGHTRAG_API_KEY=
LIGHTRAG_STORAGE_DIR=./lightrag_data
LIGHTRAG_DEFAULT_QUERY_MODE=hybrid
LIGHTRAG_START_CMD=lightrag-server

# ========== 嵌入模型配置 ==========
LIGHTRAG_EMBEDDING_API_KEY=your-embedding-api-key
LIGHTRAG_EMBEDDING_API_BASE=https://your-embedding-api-base/v1
LIGHTRAG_EMBEDDING_MODEL=text-embedding-3-small
LIGHTRAG_EMBEDDING_DIM=1536
LIGHTRAG_EMBEDDING_MAX_TOKENS=8192

# ========== 重排序模型配置 ==========
LIGHTRAG_RERANK_ENABLED=False
LIGHTRAG_RERANK_API_KEY=
LIGHTRAG_RERANK_API_BASE=
LIGHTRAG_RERANK_MODEL=
LIGHTRAG_RERANK_TOP_K=5
